import java.util.*;
class Main {
    static void findsumAvg(int[] arr){
        int sum=0;
        for(int i=0;i<arr.length;i++){
            sum+=arr[i];
        }
        System.out.println("sum is "+sum);
        System.out.println("avg is "+(sum/arr.length));
    }
    public static void main(String[] args) {
        int[] arr = {3,4,5,6,7,8};
        findsumAvg(arr);
        
    }
}
